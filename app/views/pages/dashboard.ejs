<div class="dashboard-container">
  <header class="dashboard-header">
    <div class="welcome-section">
      <h1>
        Welcome back <span class="user-email"><%= email %></span>!
      </h1>
      <p>You successfully logged in to your dashboard.</p>
    </div>
    <div class="actions-section">
      <a href="/logout" class="btn btn-logout">Logout</a>
    </div>
  </header>

  <hr class="divider" />

  <main class="dashboard-content">
    <section class="card">
      <h3>My Profile</h3>
      <p><strong>Registered email:</strong> <%= email %></p>
      <p>
        <strong>Account status:</strong>
        <span class="badge active">Active</span>
      </p>
    </section>

    <section class="card">
      <h3>Next activities</h3>
      <p>
        <ul>
          <li>Complete your profile information</li>
          <li>Explore our features and settings</li>
          <li>Connect with other users in the community</li>
        </ul>
      </p>
    </section>
  </main>
</div>
